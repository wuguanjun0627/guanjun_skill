# Copy to ~/.config/ai-media/.env and fill in values.
# Never commit real API keys.

# --- OpenAI 文生图 (gen_image.sh) ---
OPENAI_API_KEY=sk-your-key-here

# Optional: API relay / 中转（兼容 OpenAI 格式的网关）
# OPENAI_BASE_URL=https://your-relay.example.com/v1

# --- 火山方舟 文生图 / 图生视频 / 文生视频 (gen_ark_image.sh, gen_video.sh) ---
# 在火山方舟控制台 → API Key 管理 创建（按量付费，非 Coding Plan Key）
ARK_API_KEY=ark-your-key-here

# Optional: 默认即可，一般无需修改
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
# ARK_VIDEO_MODEL=doubao-seedance-1-5-pro-251215

# Optional: local proxy (OpenAI 生图时可用；火山方舟国内通常不需要)
# https_proxy=http://127.0.0.1:7890
# http_proxy=http://127.0.0.1:7890
# all_proxy=socks5://127.0.0.1:7890
